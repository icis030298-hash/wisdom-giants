[
  {
    "id": "napoleon-bonaparte.timeline.0.year",
    "sourceText": "1769년 8월 15일",
    "translatedText": "August 15, 1769"
  },
  {
    "id": "napoleon-bonaparte.timeline.0.event",
    "sourceText": "코르시카 섬의 아작시오에서 8명의 자녀 중 둘째 아들로 태어남.",
    "translatedText": "Wurde als zweiter Sohn von acht Kindern in Ajaccio auf Korsika geboren."
  },
  {
    "id": "napoleon-bonaparte.timeline.1.year",
    "sourceText": "1778년 12월",
    "translatedText": "December 1778"
  },
  {
    "id": "napoleon-bonaparte.timeline.1.event",
    "sourceText": "형 조제프와 함께 프랑스로 건너가 오탱 수도원 부속 종교학교에 입학함.",
    "translatedText": "Ging mit seinem älteren Bruder Joseph nach Frankreich und trat in die an das Kloster Autun angeschlossene Religionsschule ein."
  },
  {
    "id": "napoleon-bonaparte.timeline.2.year",
    "sourceText": "1779년 5월",
    "translatedText": "May 1779"
  },
  {
    "id": "napoleon-bonaparte.timeline.2.event",
    "sourceText": "브리엔느 유년 군사학교에 입학함.",
    "translatedText": "Trat in die Militärschule von Brienne ein."
  },
  {
    "id": "napoleon-bonaparte.timeline.3.year",
    "sourceText": "1784년 10월",
    "translatedText": "October 1784"
  },
  {
    "id": "napoleon-bonaparte.timeline.3.event",
    "sourceText": "파리 육군사관학교에 입학함.",
    "translatedText": "Trat in die Militärakademie in Paris ein."
  },
  {
    "id": "napoleon-bonaparte.timeline.4.year",
    "sourceText": "1785년 9월",
    "translatedText": "September 1785"
  },
  {
    "id": "napoleon-bonaparte.timeline.4.event",
    "sourceText": "파리 육군사관학교를 58명 중 42등으로 졸업함.",
    "translatedText": "Schloss die Pariser Militärakademie als 42. von 58 Schülern ab."
  },
  {
    "id": "napoleon-bonaparte.timeline.5.year",
    "sourceText": "1785년 10월",
    "translatedText": "October 1785"
  },
  {
    "id": "napoleon-bonaparte.timeline.5.event",
    "sourceText": "16세의 나이로 포병 소위로 임관하여 발랑스 연대에 부임함.",
    "translatedText": "Wurde im Alter von 16 Jahren als Leutnant der Artillerie in das Regiment von Valence aufgenommen."
  },
  {
    "id": "napoleon-bonaparte.timeline.6.year",
    "sourceText": "1789년 7월",
    "translatedText": "July 1789"
  },
  {
    "id": "napoleon-bonaparte.timeline.6.event",
    "sourceText": "프랑스 대혁명이 발발하자 코르시카로 귀향함.",
    "translatedText": "Kehrte bei Ausbruch der Französischen Revolution nach Korsika zurück."
  },
  {
    "id": "napoleon-bonaparte.timeline.7.year",
    "sourceText": "1792년 4월",
    "translatedText": "April 1792"
  },
  {
    "id": "napoleon-bonaparte.timeline.7.event",
    "sourceText": "코르시카 국민방위군 중령으로 선출됨.",
    "translatedText": "Wurde zum Oberstleutnant der korsischen Nationalgarde gewählt."
  },
  {
    "id": "napoleon-bonaparte.timeline.8.year",
    "sourceText": "1792년 10월",
    "translatedText": "October 1792"
  },
  {
    "id": "napoleon-bonaparte.timeline.8.event",
    "sourceText": "프랑스 정규군 대위로 진급함.",
    "translatedText": "Wurde zum Hauptmann der regulären französischen Armee befördert."
  },
  {
    "id": "napoleon-bonaparte.timeline.9.year",
    "sourceText": "1793년 6월",
    "translatedText": "June 1793"
  },
  {
    "id": "napoleon-bonaparte.timeline.9.event",
    "sourceText": "파스콸레 파올리와 갈등을 빚고 가족과 함께 코르시카에서 탈출하여 프랑스 툴롱으로 이주함.",
    "translatedText": "Geriet in Konflikt mit Pasquale Paoli, floh mit seiner Familie aus Korsika und zog nach Toulon in Frankreich."
  },
  {
    "id": "napoleon-bonaparte.timeline.10.year",
    "sourceText": "1793년 9월",
    "translatedText": "September 1793"
  },
  {
    "id": "napoleon-bonaparte.timeline.10.event",
    "sourceText": "툴롱 포위전에 포병 대위로 참전함.",
    "translatedText": "Nahm als Hauptmann der Artillerie an der Belagerung von Toulon teil."
  },
  {
    "id": "napoleon-bonaparte.timeline.11.year",
    "sourceText": "1793년 12월 18일",
    "translatedText": "December 18, 1793"
  },
  {
    "id": "napoleon-bonaparte.timeline.11.event",
    "sourceText": "툴롱을 탈환하는 데 큰 공을 세움.",
    "translatedText": "Spielte eine wichtige Rolle bei der Rückeroberung von Toulon."
  },
  {
    "id": "napoleon-bonaparte.timeline.12.year",
    "sourceText": "1793년 12월 22일",
    "translatedText": "December 22, 1793"
  },
  {
    "id": "napoleon-bonaparte.timeline.12.event",
    "sourceText": "24세의 나이에 포병 여단장(준장)으로 특진함.",
    "translatedText": "Wurde im Alter von 24 Jahren außergewöhnlich zum Brigadegeneral der Artillerie befördert."
  },
  {
    "id": "napoleon-bonaparte.timeline.13.year",
    "sourceText": "1794년 2월",
    "translatedText": "February 1794"
  },
  {
    "id": "napoleon-bonaparte.timeline.13.event",
    "sourceText": "이탈리아 방면군 포병 사령관으로 임명됨.",
    "translatedText": "Wurde zum Artilleriekommandanten der Italienarmee ernannt."
  },
  {
    "id": "napoleon-bonaparte.timeline.14.year",
    "sourceText": "1794년 7월",
    "translatedText": "July 1794"
  },
  {
    "id": "napoleon-bonaparte.timeline.14.event",
    "sourceText": "테르미도르의 반동으로 로베스피에르파로 몰려 투옥됨.",
    "translatedText": "Wurde während der Thermidor-Reaktion als Anhänger Robespierres inhaftiert."
  },
  {
    "id": "napoleon-bonaparte.timeline.15.year",
    "sourceText": "1794년 8월",
    "translatedText": "August 1794"
  },
  {
    "id": "napoleon-bonaparte.timeline.15.event",
    "sourceText": "혐의가 풀려 석방됨.",
    "translatedText": "Wurde von den Anschuldigungen freigesprochen und aus der Haft entlassen."
  },
  {
    "id": "napoleon-bonaparte.timeline.16.year",
    "sourceText": "1795년 5월",
    "translatedText": "May 1795"
  },
  {
    "id": "napoleon-bonaparte.timeline.16.event",
    "sourceText": "방데 반란 진압군 보병 여단장으로 발령되었으나 부임을 거부함.",
    "translatedText": "Wurde zum Infanterie-Brigadegeneral zur Unterdrückung des Aufstands in der Vendée ernannt, lehnte den Posten jedoch ab."
  },
  {
    "id": "napoleon-bonaparte.timeline.17.year",
    "sourceText": "1795년 9월",
    "translatedText": "September 1795"
  },
  {
    "id": "napoleon-bonaparte.timeline.17.event",
    "sourceText": "보병 여단장 부임 거부로 인해 공안위원회로부터 강제 전역 처분을 받음.",
    "translatedText": "Wurde vom Wohlfahrtsausschuss zwangsweise aus der Armee entlassen, da er die Position als Infanterie-Brigadegeneral ablehnte."
  },
  {
    "id": "napoleon-bonaparte.timeline.18.year",
    "sourceText": "1795년 10월 5일",
    "translatedText": "October 5, 1795"
  },
  {
    "id": "napoleon-bonaparte.timeline.18.event",
    "sourceText": "방데미에르 13일의 반란을 진압함.",
    "translatedText": "Schlug den Aufstand des 13. Vendémiaire nieder."
  },
  {
    "id": "napoleon-bonaparte.timeline.19.year",
    "sourceText": "1795년 10월 16일",
    "translatedText": "October 16, 1795"
  },
  {
    "id": "napoleon-bonaparte.timeline.19.event",
    "sourceText": "사단장으로 승진하여 국내군 사령관에 임명됨.",
    "translatedText": "Wurde zum Divisionsgeneral befördert und zum Befehlshaber der Heimatstreitkräfte ernannt."
  },
  {
    "id": "napoleon-bonaparte.timeline.20.year",
    "sourceText": "1796년 3월 2일",
    "translatedText": "March 2, 1796"
  },
  {
    "id": "napoleon-bonaparte.timeline.20.event",
    "sourceText": "이탈리아 원정군 총사령관으로 임명됨.",
    "translatedText": "Wurde zum Oberbefehlshaber der Italienarmee ernannt."
  },
  {
    "id": "napoleon-bonaparte.timeline.21.year",
    "sourceText": "1796년 3월 9일",
    "translatedText": "March 9, 1796"
  },
  {
    "id": "napoleon-bonaparte.timeline.21.event",
    "sourceText": "조제핀 드 보아르네와 결혼함.",
    "translatedText": "Heiratete Joséphine de Beauharnais."
  },
  {
    "id": "napoleon-bonaparte.timeline.22.year",
    "sourceText": "1796년 4월",
    "translatedText": "April 1796"
  },
  {
    "id": "napoleon-bonaparte.timeline.22.event",
    "sourceText": "이탈리아 원정을 시작함.",
    "translatedText": "Begann den Italienfeldzug."
  },
  {
    "id": "napoleon-bonaparte.timeline.23.year",
    "sourceText": "1797년 1월 14일",
    "translatedText": "January 14, 1797"
  },
  {
    "id": "napoleon-bonaparte.timeline.23.event",
    "sourceText": "리볼리 전투에서 오스트리아군을 격파함.",
    "translatedText": "Besiegte die österreichische Armee in der Schlacht von Rivoli."
  },
  {
    "id": "napoleon-bonaparte.timeline.24.year",
    "sourceText": "1797년 10월 17일",
    "translatedText": "October 17, 1797"
  },
  {
    "id": "napoleon-bonaparte.timeline.24.event",
    "sourceText": "캄포포르미오 조약을 체결하여 제1차 대프랑스 동맹을 붕괴시킴.",
    "translatedText": "Unterzeichnete den Vertrag von Campo Formio, wodurch die Erste Koalition gegen Frankreich zusammenbrach."
  },
  {
    "id": "napoleon-bonaparte.timeline.25.year",
    "sourceText": "1797년 12월 5일",
    "translatedText": "December 5, 1797"
  },
  {
    "id": "napoleon-bonaparte.timeline.25.event",
    "sourceText": "국민적 영웅으로 환영받으며 파리로 귀환함.",
    "translatedText": "Kehrte als Nationalheld gefeiert nach Paris zurück."
  },
  {
    "id": "napoleon-bonaparte.timeline.26.year",
    "sourceText": "1798년 5월 19일",
    "translatedText": "May 19, 1798"
  },
  {
    "id": "napoleon-bonaparte.timeline.26.event",
    "sourceText": "이집트 원정을 위해 툴롱 항을 출발함.",
    "translatedText": "Lief vom Hafen Toulon zum Ägyptenfeldzug aus."
  },
  {
    "id": "napoleon-bonaparte.timeline.27.year",
    "sourceText": "1798년 7월 21일",
    "translatedText": "July 21, 1798"
  },
  {
    "id": "napoleon-bonaparte.timeline.27.event",
    "sourceText": "피라미드 전투에서 맘루크 군대를 격파함.",
    "translatedText": "Besiegte die Mamlukenarmee in der Schlacht bei den Pyramiden."
  },
  {
    "id": "napoleon-bonaparte.timeline.28.year",
    "sourceText": "1798년 8월 1일",
    "translatedText": "August 1, 1798"
  },
  {
    "id": "napoleon-bonaparte.timeline.28.event",
    "sourceText": "나일 해전에서 넬슨이 이끄는 영국 함대에게 패배함.",
    "translatedText": "Wurde in der Seeschlacht bei Abukir von der britischen Flotte unter Nelson besiegt."
  },
  {
    "id": "napoleon-bonaparte.timeline.29.year",
    "sourceText": "1799년 8월 22일",
    "translatedText": "August 22, 1799"
  },
  {
    "id": "napoleon-bonaparte.timeline.29.event",
    "sourceText": "군대를 이집트에 남겨둔 채 소수의 측근만 데리고 몰래 프랑스로 귀환함.",
    "translatedText": "Ließ die Armee in Ägypten zurück und kehrte heimlich mit wenigen Vertrauten nach Frankreich zurück."
  },
  {
    "id": "napoleon-bonaparte.timeline.30.year",
    "sourceText": "1799년 11월 9일",
    "translatedText": "November 9, 1799"
  },
  {
    "id": "napoleon-bonaparte.timeline.30.event",
    "sourceText": "브뤼메르 18일의 쿠데타를 일으켜 총재 정부를 전복함.",
    "translatedText": "Führte den Staatsstreich des 18. Brumaire durch und stürzte das Direktorium."
  },
  {
    "id": "napoleon-bonaparte.timeline.31.year",
    "sourceText": "1799년 11월 10일",
    "translatedText": "November 10, 1799"
  },
  {
    "id": "napoleon-bonaparte.timeline.31.event",
    "sourceText": "통령 정부를 수립하고 제1통령으로 취임하여 실권을 장악함.",
    "translatedText": "Errichtete die Konsulatsregierung, wurde Erster Konsul und ergriff die tatsächliche Macht."
  },
  {
    "id": "napoleon-bonaparte.timeline.32.year",
    "sourceText": "1800년 5월",
    "translatedText": "May 1800"
  },
  {
    "id": "napoleon-bonaparte.timeline.32.event",
    "sourceText": "알프스 산맥을 넘어 이탈리아로 진격함.",
    "translatedText": "Überquerte die Alpen und rückte nach Italien vor."
  },
  {
    "id": "napoleon-bonaparte.timeline.33.year",
    "sourceText": "1800년 6월 14일",
    "translatedText": "June 14, 1800"
  },
  {
    "id": "napoleon-bonaparte.timeline.33.event",
    "sourceText": "마렝고 전투에서 오스트리아군을 상대로 극적인 승리를 거둠.",
    "translatedText": "Errang in der Schlacht bei Marengo einen dramatischen Sieg gegen die österreichische Armee."
  },
  {
    "id": "napoleon-bonaparte.timeline.34.year",
    "sourceText": "1801년 2월 9일",
    "translatedText": "February 9, 1801"
  },
  {
    "id": "napoleon-bonaparte.timeline.34.event",
    "sourceText": "오스트리아와 뤼네빌 조약을 체결함.",
    "translatedText": "Unterzeichnete den Frieden von Lunéville mit Österreich."
  },
  {
    "id": "napoleon-bonaparte.timeline.35.year",
    "sourceText": "1801년 7월 15일",
    "translatedText": "July 15, 1801"
  },
  {
    "id": "napoleon-bonaparte.timeline.35.event",
    "sourceText": "교황 비오 7세와 정교 조약(콩코르다투스)을 체결하여 가톨릭교회와 화해함.",
    "translatedText": "Unterzeichnete ein Konkordat mit Papst Pius VII. und söhnte sich mit der katholischen Kirche aus."
  },
  {
    "id": "napoleon-bonaparte.timeline.36.year",
    "sourceText": "1802년 3월 25일",
    "translatedText": "March 25, 1802"
  },
  {
    "id": "napoleon-bonaparte.timeline.36.event",
    "sourceText": "영국과 아미앵 조약을 체결하여 평화를 이룩함.",
    "translatedText": "Unterzeichnete den Frieden von Amiens mit Großbritannien und stellte den Frieden her."
  },
  {
    "id": "napoleon-bonaparte.timeline.37.year",
    "sourceText": "1802년 8월 2일",
    "translatedText": "August 2, 1802"
  },
  {
    "id": "napoleon-bonaparte.timeline.37.event",
    "sourceText": "국민 투표를 통해 종신 통령으로 취임함.",
    "translatedText": "Wurde durch eine Volksabstimmung zum Konsul auf Lebenszeit."
  },
  {
    "id": "napoleon-bonaparte.timeline.38.year",
    "sourceText": "1804년 3월 21일",
    "translatedText": "March 21, 1804"
  },
  {
    "id": "napoleon-bonaparte.timeline.38.event",
    "sourceText": "프랑스 민법전(나폴레옹 법전)을 반포함.",
    "translatedText": "Verkündete das französische Zivilgesetzbuch (Code Napoléon)."
  },
  {
    "id": "napoleon-bonaparte.timeline.39.year",
    "sourceText": "1804년 5월 18일",
    "translatedText": "May 18, 1804"
  },
  {
    "id": "napoleon-bonaparte.timeline.39.event",
    "sourceText": "원로원으로부터 프랑스인의 황제로 추대됨.",
    "translatedText": "Wurde vom Senat zum Kaiser der Franzosen ernannt."
  },
  {
    "id": "napoleon-bonaparte.timeline.40.year",
    "sourceText": "1804년 12월 2일",
    "translatedText": "December 2, 1804"
  },
  {
    "id": "napoleon-bonaparte.timeline.40.event",
    "sourceText": "파리 노트르담 대성당에서 황제 대관식을 거행함.",
    "translatedText": "Hielt seine Kaiserkrönung in der Kathedrale Notre-Dame in Paris ab."
  },
  {
    "id": "napoleon-bonaparte.timeline.41.year",
    "sourceText": "1805년 10월 21일",
    "translatedText": "October 21, 1805"
  },
  {
    "id": "napoleon-bonaparte.timeline.41.event",
    "sourceText": "트라팔가르 해전에서 영국 해군에게 대패함.",
    "translatedText": "Erlitt in der Schlacht von Trafalgar eine schwere Niederlage gegen die britische Marine."
  },
  {
    "id": "napoleon-bonaparte.timeline.42.year",
    "sourceText": "1805년 12월 2일",
    "translatedText": "December 2, 1805"
  },
  {
    "id": "napoleon-bonaparte.timeline.42.event",
    "sourceText": "아우스터리츠 전투(삼제회전)에서 오스트리아-러시아 연합군을 대파함.",
    "translatedText": "Besiegte die österreichisch-russischen Koalitionstruppen in der Schlacht bei Austerlitz (Drei-Kaiser-Schlacht)."
  },
  {
    "id": "napoleon-bonaparte.timeline.43.year",
    "sourceText": "1806년 11월",
    "translatedText": "November 1806"
  },
  {
    "id": "napoleon-bonaparte.timeline.43.event",
    "sourceText": "베를린 칙령을 통해 대륙봉쇄령을 내림.",
    "translatedText": "Erließ durch das Berliner Dekret die Kontinentalsperre."
  },
  {
    "id": "napoleon-bonaparte.timeline.44.year",
    "sourceText": "1807년",
    "translatedText": "1807"
  },
  {
    "id": "napoleon-bonaparte.timeline.44.event",
    "sourceText": "러시아의 알렉산드르 1세와 틸지트 조약을 체결함.",
    "translatedText": "Unterzeichnete den Frieden von Tilsit mit Zar Alexander I. von Russland."
  },
  {
    "id": "napoleon-bonaparte.timeline.45.year",
    "sourceText": "1807년 11월",
    "translatedText": "November 1807"
  },
  {
    "id": "napoleon-bonaparte.timeline.45.event",
    "sourceText": "포르투갈이 대륙봉쇄령을 어기자 포르투갈을 침공함.",
    "translatedText": "Fiel in Portugal ein, da es die Kontinentalsperre verletzte."
  },
  {
    "id": "napoleon-bonaparte.timeline.46.year",
    "sourceText": "1808년 2월",
    "translatedText": "February 1808"
  },
  {
    "id": "napoleon-bonaparte.timeline.46.event",
    "sourceText": "로마를 점령함.",
    "translatedText": "Besetzte Rom."
  },
  {
    "id": "napoleon-bonaparte.timeline.47.year",
    "sourceText": "1808년 5월 2일",
    "translatedText": "May 2, 1808"
  },
  {
    "id": "napoleon-bonaparte.timeline.47.event",
    "sourceText": "마드리드 주민들이 프랑스 군대에 대항하여 폭동을 일으킴.",
    "translatedText": "Die Einwohner von Madrid erhoben sich gegen die französische Armee."
  },
  {
    "id": "napoleon-bonaparte.timeline.48.year",
    "sourceText": "1809년 5월",
    "translatedText": "May 1809"
  },
  {
    "id": "napoleon-bonaparte.timeline.48.event",
    "sourceText": "교황령을 합병함.",
    "translatedText": "Annektierte den Kirchenstaat."
  },
  {
    "id": "napoleon-bonaparte.timeline.49.year",
    "sourceText": "1809년 6월 10일",
    "translatedText": "June 10, 1809"
  },
  {
    "id": "napoleon-bonaparte.timeline.49.event",
    "sourceText": "교황이 파문을 선포하자 체포하여 사보나에 유폐시킴.",
    "translatedText": "Verhaftete den Papst nach dessen Exkommunikation und verbannte ihn nach Savona."
  },
  {
    "id": "napoleon-bonaparte.timeline.50.year",
    "sourceText": "1810년 1월 10일",
    "translatedText": "January 10, 1810"
  },
  {
    "id": "napoleon-bonaparte.timeline.50.event",
    "sourceText": "황후 조제핀과 이혼함.",
    "translatedText": "Ließ sich von Kaiserin Joséphine scheiden."
  },
  {
    "id": "napoleon-bonaparte.timeline.51.year",
    "sourceText": "1810년",
    "translatedText": "1810"
  },
  {
    "id": "napoleon-bonaparte.timeline.51.event",
    "sourceText": "오스트리아 황제 프란츠 1세의 딸 마리 루이즈와 재혼함.",
    "translatedText": "Heiratete Marie-Louise, die Tochter des österreichischen Kaisers Franz I."
  },
  {
    "id": "napoleon-bonaparte.timeline.52.year",
    "sourceText": "1810년",
    "translatedText": "1810"
  },
  {
    "id": "napoleon-bonaparte.timeline.52.event",
    "sourceText": "스웨덴이 프랑스 육군 원수 베르나도트에게 스웨덴 차기 왕위계승을 제의함.",
    "translatedText": "Schweden bot dem französischen Marschall Bernadotte die Thronfolge an."
  },
  {
    "id": "napoleon-bonaparte.timeline.53.year",
    "sourceText": "1811년",
    "translatedText": "1811"
  },
  {
    "id": "napoleon-bonaparte.timeline.53.event",
    "sourceText": "마리 루이즈가 로마왕 나폴레옹 2세를 낳음.",
    "translatedText": "Marie-Louise gebar Napoléon II., den König von Rom."
  },
  {
    "id": "napoleon-bonaparte.timeline.54.year",
    "sourceText": "1812년 5월",
    "translatedText": "May 1812"
  },
  {
    "id": "napoleon-bonaparte.timeline.54.event",
    "sourceText": "60만 대군을 이끌고 러시아 원정을 실시함.",
    "translatedText": "Unternahm mit einer 600.000 Mann starken Armee den Russlandfeldzug."
  },
  {
    "id": "napoleon-bonaparte.timeline.55.year",
    "sourceText": "1812년 5월",
    "translatedText": "May 1812"
  },
  {
    "id": "napoleon-bonaparte.timeline.55.event",
    "sourceText": "교황을 퐁텐블로로 강제 이송함.",
    "translatedText": "Ließ den Papst gewaltsam nach Fontainebleau bringen."
  },
  {
    "id": "napoleon-bonaparte.timeline.56.year",
    "sourceText": "1812년 9월 7일",
    "translatedText": "September 7, 1812"
  },
  {
    "id": "napoleon-bonaparte.timeline.56.event",
    "sourceText": "보로디노 근처에서 벌어진 대전투에서 프랑스 군이 승리함.",
    "translatedText": "Die französische Armee siegte in der großen Schlacht bei Borodino."
  },
  {
    "id": "napoleon-bonaparte.timeline.57.year",
    "sourceText": "1812년 9월 15일",
    "translatedText": "September 15, 1812"
  },
  {
    "id": "napoleon-bonaparte.timeline.57.event",
    "sourceText": "모스크바를 점령함.",
    "translatedText": "Besetzte Moskau."
  },
  {
    "id": "napoleon-bonaparte.timeline.58.year",
    "sourceText": "1812년 10월",
    "translatedText": "October 1812"
  },
  {
    "id": "napoleon-bonaparte.timeline.58.event",
    "sourceText": "프랑스군이 러시아에서 퇴각함.",
    "translatedText": "Die französische Armee zog sich aus Russland zurück."
  },
  {
    "id": "napoleon-bonaparte.timeline.59.year",
    "sourceText": "1813년 1월",
    "translatedText": "January 1813"
  },
  {
    "id": "napoleon-bonaparte.timeline.59.event",
    "sourceText": "교황 비오 7세와 '퐁텐블로 정교조약'에 서명함.",
    "translatedText": "Unterzeichnete das Konkordat von Fontainebleau mit Papst Pius VII."
  },
  {
    "id": "napoleon-bonaparte.timeline.60.year",
    "sourceText": "1813년 10월 16일",
    "translatedText": "October 16, 1813"
  },
  {
    "id": "napoleon-bonaparte.timeline.60.event",
    "sourceText": "라이프치히 전투에서 동맹군에게 포위공격 당하여 대패함.",
    "translatedText": "Wurde in der Völkerschlacht bei Leipzig von den alliierten Truppen belagert und vernichtend geschlagen."
  },
  {
    "id": "napoleon-bonaparte.timeline.61.year",
    "sourceText": "1814년 3월 31일",
    "translatedText": "March 31, 1814"
  },
  {
    "id": "napoleon-bonaparte.timeline.61.event",
    "sourceText": "프랑스의 수도 파리가 함락됨.",
    "translatedText": "Die französische Hauptstadt Paris fiel."
  },
  {
    "id": "napoleon-bonaparte.timeline.62.year",
    "sourceText": "1814년 4월 16일",
    "translatedText": "April 16, 1814"
  },
  {
    "id": "napoleon-bonaparte.timeline.62.event",
    "sourceText": "퐁텐블로 조약을 체결한 뒤 엘바섬의 영주로 추방됨.",
    "translatedText": "Wurde nach Unterzeichnung des Vertrags von Fontainebleau als Herrscher auf die Insel Elba verbannt."
  },
  {
    "id": "napoleon-bonaparte.timeline.63.year",
    "sourceText": "1815년 2월",
    "translatedText": "February 1815"
  },
  {
    "id": "napoleon-bonaparte.timeline.63.event",
    "sourceText": "엘바섬을 탈출함.",
    "translatedText": "Floh von der Insel Elba."
  },
  {
    "id": "napoleon-bonaparte.timeline.64.year",
    "sourceText": "1815년 3월 20일",
    "translatedText": "March 20, 1815"
  },
  {
    "id": "napoleon-bonaparte.timeline.64.event",
    "sourceText": "파리에 입성하여 프랑스 황제로 복위함.",
    "translatedText": "Zog in Paris ein und wurde wieder Kaiser der Franzosen."
  },
  {
    "id": "napoleon-bonaparte.timeline.65.year",
    "sourceText": "1815년 6월",
    "translatedText": "June 1815"
  },
  {
    "id": "napoleon-bonaparte.timeline.65.event",
    "sourceText": "워털루 전투에서 영국과 프로이센의 연합 공격으로 패배하며 백일천하가 끝남.",
    "translatedText": "Wurde in der Schlacht bei Waterloo durch einen gemeinsamen Angriff Großbritanniens und Preußens besiegt, was die Herrschaft der Hundert Tage beendete."
  },
  {
    "id": "napoleon-bonaparte.timeline.66.year",
    "sourceText": "1815년 8월",
    "translatedText": "August 1815"
  },
  {
    "id": "napoleon-bonaparte.timeline.66.event",
    "sourceText": "남대서양의 세인트헬레나에 유폐됨.",
    "translatedText": "Wurde auf St. Helena im Südatlantik ins Exil geschickt."
  },
  {
    "id": "napoleon-bonaparte.timeline.67.year",
    "sourceText": "1821년 5월 5일",
    "translatedText": "May 5, 1821"
  },
  {
    "id": "napoleon-bonaparte.timeline.67.event",
    "sourceText": "오후 5시 49분에 세상을 떠남.",
    "translatedText": "Verstarb um 17:49 Uhr."
  },
  {
    "id": "napoleon-bonaparte.timeline.68.year",
    "sourceText": "1840년 5월",
    "translatedText": "May 1840"
  },
  {
    "id": "napoleon-bonaparte.timeline.68.event",
    "sourceText": "유해가 프랑스에 반환되어 파리의 앵발리드에 안치됨.",
    "translatedText": "Seine sterblichen Überreste wurden nach Frankreich überführt und im Invalidendom in Paris beigesetzt."
  },
  {
    "id": "napoleon-bonaparte.keyAchievements.0.title",
    "sourceText": "나폴레옹 법전 제정",
    "translatedText": "Einführung des Code Napoléon"
  },
  {
    "id": "napoleon-bonaparte.keyAchievements.0.description",
    "sourceText": "1804년에 《프랑스 민법전》, 이른바 나폴레옹 법전을 제정하여 전 세계의 민법에 많은 영향을 미쳤다.",
    "translatedText": "Er erließ 1804 das französische Zivilgesetzbuch, den sogenannten Code Napoléon, der das Zivilrecht weltweit stark beeinflusste."
  },
  {
    "id": "napoleon-bonaparte.keyAchievements.1.title",
    "sourceText": "군사 전술 및 제도 발전",
    "translatedText": "Entwicklung militärischer Taktiken und Systeme"
  },
  {
    "id": "napoleon-bonaparte.keyAchievements.1.description",
    "sourceText": "군사적으로 현대전에까지 영향을 끼쳤고 전술, 전략, 훈련, 조직, 군수, 의복과 포상 제도를 발전시켰다.",
    "translatedText": "Er hatte einen militärischen Einfluss, der bis in die moderne Kriegsführung reicht, und entwickelte Taktik, Strategie, Ausbildung, Organisation, Logistik, Uniformierung und das Belohnungssystem weiter."
  },
  {
    "id": "napoleon-bonaparte.keyAchievements.2.title",
    "sourceText": "툴롱 포위전 승리",
    "translatedText": "Sieg bei der Belagerung von Toulon"
  },
  {
    "id": "napoleon-bonaparte.keyAchievements.2.description",
    "sourceText": "1793년 툴롱 포위전에서 승리를 이끈 후 24살에 준장으로 진급하여 장군이 되었다.",
    "translatedText": "Nachdem er 1793 zum Sieg bei der Belagerung von Toulon geführt hatte, wurde er im Alter von 24 Jahren zum Brigadegeneral befördert."
  },
  {
    "id": "napoleon-bonaparte.keyAchievements.3.title",
    "sourceText": "이탈리아 원정 성공",
    "translatedText": "Erfolgreicher Italienfeldzug"
  },
  {
    "id": "napoleon-bonaparte.keyAchievements.3.description",
    "sourceText": "1796년 이탈리아 원정에서 대성공을 거두는 등 제1차 대프랑스 동맹 전쟁에서 연승하며 군인으로서 승승장구하였다.",
    "translatedText": "Er erzielte 1796 große Erfolge im Italienfeldzug, gewann wiederholt im Ersten Koalitionskrieg und machte eine steile militärische Karriere."
  },
  {
    "id": "napoleon-bonaparte.keyAchievements.4.title",
    "sourceText": "프랑스 은행 설립",
    "translatedText": "Gründung der Bank von Frankreich"
  },
  {
    "id": "napoleon-bonaparte.keyAchievements.4.description",
    "sourceText": "1800년에 프랑스 은행을 설립하여 경제 안정을 도모했다.",
    "translatedText": "Er gründete 1800 die Bank von Frankreich, um die wirtschaftliche Stabilität zu fördern."
  },
  {
    "id": "napoleon-bonaparte.keyAchievements.5.title",
    "sourceText": "레지옹 도뇌르 훈장 창설",
    "translatedText": "Stiftung der Ehrenlegion"
  },
  {
    "id": "napoleon-bonaparte.keyAchievements.5.description",
    "sourceText": "1802년에 유명한 레지옹 도뇌르 훈장을 창설했다.",
    "translatedText": "Er stiftete 1802 die berühmte Ehrenlegion (Légion d'honneur)."
  }
]
