[
  {"id":"napoleon-bonaparte.timeline.0.year","translatedText":"August 15, 1769"},
  {"id":"napoleon-bonaparte.timeline.0.event","translatedText":"Korsika'nın Ajaccio şehrinde 8 çocuğun ikincisi olarak doğdu."},
  {"id":"napoleon-bonaparte.timeline.1.year","translatedText":"December 1778"},
  {"id":"napoleon-bonaparte.timeline.1.event","translatedText":"Ağabeyi Joseph ile birlikte Fransa'ya gitti ve Autun Manastırı'na bağlı dini okula girdi."},
  {"id":"napoleon-bonaparte.timeline.2.year","translatedText":"May 1779"},
  {"id":"napoleon-bonaparte.timeline.2.event","translatedText":"Brienne Askeri Okulu'na girdi."},
  {"id":"napoleon-bonaparte.timeline.3.year","translatedText":"October 1784"},
  {"id":"napoleon-bonaparte.timeline.3.event","translatedText":"Paris Askeri Akademisi'ne girdi."},
  {"id":"napoleon-bonaparte.timeline.4.year","translatedText":"February 24, 1785"},
  {"id":"napoleon-bonaparte.timeline.4.event","translatedText":"Babası Carlo mide kanserinden öldü."},
  {"id":"napoleon-bonaparte.timeline.5.year","translatedText":"September 1785"},
  {"id":"napoleon-bonaparte.timeline.5.event","translatedText":"Topçu subaylığı sınavını geçerek 16 yaşında teğmen olarak atandı."},
  {"id":"napoleon-bonaparte.timeline.6.year","translatedText":"November 3, 1785"},
  {"id":"napoleon-bonaparte.timeline.6.event","translatedText":"Valence'te konuşlanmış olan La Fère Alayı'na topçu subayı olarak atandı."},
  {"id":"napoleon-bonaparte.timeline.7.year","translatedText":"1788"},
  {"id":"napoleon-bonaparte.timeline.7.event","translatedText":"La Fère Alayı Auxonne'a taşınınca orada görev yaptı."},
  {"id":"napoleon-bonaparte.timeline.8.year","translatedText":"July 1789"},
  {"id":"napoleon-bonaparte.timeline.8.event","translatedText":"Fransız Devrimi patlak verdi."},
  {"id":"napoleon-bonaparte.timeline.9.year","translatedText":"Late September 1789"},
  {"id":"napoleon-bonaparte.timeline.9.event","translatedText":"İzin alarak memleketi Korsika'ya döndü."},
  {"id":"napoleon-bonaparte.timeline.10.year","translatedText":"January 1793"},
  {"id":"napoleon-bonaparte.timeline.10.event","translatedText":"XVI. Louis idam edildi."},
  {"id":"napoleon-bonaparte.timeline.11.year","translatedText":"May 1793"},
  {"id":"napoleon-bonaparte.timeline.11.event","translatedText":"Paoli taraftarları tarafından gözaltına alınıp evi ve çiftliği yağmalandıktan sonra ailesiyle birlikte Korsika'dan kaçtı."},
  {"id":"napoleon-bonaparte.timeline.12.year","translatedText":"December 18, 1793"},
  {"id":"napoleon-bonaparte.timeline.12.event","translatedText":"Toulon Kuşatması'nda L'Eguillette ve Balaguier kalelerini geri alarak zafer kazandı ve tuğgeneralliğe terfi etti."},
  {"id":"napoleon-bonaparte.timeline.13.year","translatedText":"July 27, 1794"},
  {"id":"napoleon-bonaparte.timeline.13.event","translatedText":"Thermidor Gericiliği gerçekleşti ve Robespierre ile yandaşları idam edildi."},
  {"id":"napoleon-bonaparte.timeline.14.year","translatedText":"August 1794"},
  {"id":"napoleon-bonaparte.timeline.14.event","translatedText":"Robespierre'in kardeşi Augustin ile olan yakınlığı nedeniyle hapsedildi, ancak kısa süre sonra serbest bırakıldı."},
  {"id":"napoleon-bonaparte.timeline.15.year","translatedText":"October 5, 1795"},
  {"id":"napoleon-bonaparte.timeline.15.event","translatedText":"Paris'te çıkan kralcı ayaklanmayı bastırdı."},
  {"id":"napoleon-bonaparte.timeline.16.year","translatedText":"March 9, 1796"},
  {"id":"napoleon-bonaparte.timeline.16.event","translatedText":"Joséphine de Beauharnais ile evlendi."},
  {"id":"napoleon-bonaparte.timeline.17.year","translatedText":"1796"},
  {"id":"napoleon-bonaparte.timeline.17.event","translatedText":"İtalya Seferi Ordusu komutanlığına atandı."},
  {"id":"napoleon-bonaparte.timeline.18.year","translatedText":"1797"},
  {"id":"napoleon-bonaparte.timeline.18.event","translatedText":"Avusturya'nın başkenti Viyana'yı işgal etti ve Campo Formio Antlaşması'nı imzaladı."},
  {"id":"napoleon-bonaparte.timeline.19.year","translatedText":"May 1798"},
  {"id":"napoleon-bonaparte.timeline.19.event","translatedText":"50.000'den fazla askerle Mısır'ın İskenderiye limanına çıkarak Mısır Seferi'ni başlattı."},
  {"id":"napoleon-bonaparte.timeline.20.year","translatedText":"August 1799"},
  {"id":"napoleon-bonaparte.timeline.20.event","translatedText":"Fransız donanması, Abukir Körfezi'nde Horatio Nelson'un İngiliz donanmasına yenildi."},
  {"id":"napoleon-bonaparte.timeline.21.year","translatedText":"October 1799"},
  {"id":"napoleon-bonaparte.timeline.21.event","translatedText":"Mısır'dan kaçarak Fransa'ya döndü."},
  {"id":"napoleon-bonaparte.timeline.22.year","translatedText":"November 9, 1799"},
  {"id":"napoleon-bonaparte.timeline.22.event","translatedText":"Devrim hükümetinin güçlü ismi Sieyès ile birlikte Brumaire Darbesi'ni gerçekleştirdi."},
  {"id":"napoleon-bonaparte.timeline.23.year","translatedText":"February 7, 1800"},
  {"id":"napoleon-bonaparte.timeline.23.event","translatedText":"Üç konsül öngören yeni anayasa referanduma sunularak kabul edildi."},
  {"id":"napoleon-bonaparte.timeline.24.year","translatedText":"May 1800"},
  {"id":"napoleon-bonaparte.timeline.24.event","translatedText":"Fransız seferi ordusu Saint-Bernard Geçidi'ni aştı."},
  {"id":"napoleon-bonaparte.timeline.25.year","translatedText":"June 1800"},
  {"id":"napoleon-bonaparte.timeline.25.event","translatedText":"Avusturya ordusuyla karşılaştığı Marengo Muharebesi'nde zafer kazandı."},
  {"id":"napoleon-bonaparte.timeline.26.year","translatedText":"1800"},
  {"id":"napoleon-bonaparte.timeline.26.event","translatedText":"Ekonomik istikrarı sağlamak amacıyla Fransa Merkez Bankası'nı kurdu."},
  {"id":"napoleon-bonaparte.timeline.27.year","translatedText":"1800"},
  {"id":"napoleon-bonaparte.timeline.27.event","translatedText":"Mortefontaine Antlaşması ile ABD ile olan ilişkileri dostane bir şekilde sonuçlandırdı."},
  {"id":"napoleon-bonaparte.timeline.28.year","translatedText":"1801"},
  {"id":"napoleon-bonaparte.timeline.28.event","translatedText":"Papa VII. Pius ile siyasi ve dini bir konkordato imzaladı."},
  {"id":"napoleon-bonaparte.timeline.29.year","translatedText":"November 1801"},
  {"id":"napoleon-bonaparte.timeline.29.event","translatedText":"Koloniyi geri almak ve köleliği yeniden canlandırmak amacıyla Haiti'ye (Saint-Domingue) 30.000 kişilik bir seferi kuvvet gönderdi."},
  {"id":"napoleon-bonaparte.timeline.30.year","translatedText":"March 1802"},
  {"id":"napoleon-bonaparte.timeline.30.event","translatedText":"İngiltere ile Amiens Antlaşması'nı imzalayarak 10 yıl aradan sonra barışı sağladı."},
  {"id":"napoleon-bonaparte.timeline.31.year","translatedText":"1802"},
  {"id":"napoleon-bonaparte.timeline.31.event","translatedText":"Légion d'honneur Nişanı'nı kurdu."},
  {"id":"napoleon-bonaparte.timeline.32.year","translatedText":"August 2, 1802"},
  {"id":"napoleon-bonaparte.timeline.32.event","translatedText":"Ömür boyu konsül olarak diktatörlük yetkilerini güçlendirdi."},
  {"id":"napoleon-bonaparte.timeline.33.year","translatedText":"April 1803"},
  {"id":"napoleon-bonaparte.timeline.33.event","translatedText":"Louisiana'yı 15 milyon dolara ABD'ye sattı."},
  {"id":"napoleon-bonaparte.timeline.34.year","translatedText":"August 1803"},
  {"id":"napoleon-bonaparte.timeline.34.event","translatedText":"Napolyon'a karşı çıkan ve Bourbon restorasyonunu uman Georges Cadoudal ile kralcıların suikast planı ortaya çıkarıldı."},
  {"id":"napoleon-bonaparte.timeline.35.year","translatedText":"November 1803"},
  {"id":"napoleon-bonaparte.timeline.35.event","translatedText":"Haiti'yi işgalden vazgeçerek birliklerini geri çekti."},
  {"id":"napoleon-bonaparte.timeline.36.year","translatedText":"January 1, 1804"},
  {"id":"napoleon-bonaparte.timeline.36.event","translatedText":"Haiti resmen bağımsızlığını ilan ederek ilk siyahi cumhuriyet oldu."},
  {"id":"napoleon-bonaparte.timeline.37.year","translatedText":"July 1804"},
  {"id":"napoleon-bonaparte.timeline.37.event","translatedText":"İmparatorluğun kabulü referandumla kararlaştırıldı."},
  {"id":"napoleon-bonaparte.timeline.38.year","translatedText":"December 2, 1804"},
  {"id":"napoleon-bonaparte.timeline.38.event","translatedText":"Notre Dame Katedrali'nde taç giyme töreni düzenleyerek Fransız İmparatorluğu'nun ilk imparatoru I. Napolyon oldu."},
  {"id":"napoleon-bonaparte.timeline.39.year","translatedText":"October 1805"},
  {"id":"napoleon-bonaparte.timeline.39.event","translatedText":"Trafalgar Muharebesi'nde Fransız donanması, Nelson komutasındaki İngiliz donanmasına ağır bir şekilde yenildi."},
  {"id":"napoleon-bonaparte.timeline.40.year","translatedText":"December 2, 1805"},
  {"id":"napoleon-bonaparte.timeline.40.event","translatedText":"Austerlitz Muharebesi'nde Fransız ordusu kesin bir zafer kazandı ve Avusturya, Pressburg Antlaşması'nı imzalayarak teslim oldu."},
  {"id":"napoleon-bonaparte.timeline.41.year","translatedText":"June 1806"},
  {"id":"napoleon-bonaparte.timeline.41.event","translatedText":"Kardeşi Louis'yi Hollanda Kralı yaptı."},
  {"id":"napoleon-bonaparte.timeline.42.year","translatedText":"October 1806"},
  {"id":"napoleon-bonaparte.timeline.42.event","translatedText":"Jena-Auerstedt Muharebesi'nde Prusya ordusunu mağlup ederek Berlin'e girdi."},
  {"id":"napoleon-bonaparte.timeline.43.year","translatedText":"November 1806"},
  {"id":"napoleon-bonaparte.timeline.43.event","translatedText":"Berlin Kararnamesi ile Kıta Ablukası'nı ilan etti."},
  {"id":"napoleon-bonaparte.timeline.44.year","translatedText":"1807"},
  {"id":"napoleon-bonaparte.timeline.44.event","translatedText":"Rusya İmparatoru I. Aleksandr ile Tilsit Antlaşması'nı imzaladı."},
  {"id":"napoleon-bonaparte.timeline.45.year","translatedText":"November 1807"},
  {"id":"napoleon-bonaparte.timeline.45.event","translatedText":"Portekiz Kıta Ablukası'nı ihlal edince Portekiz'i işgal etti."},
  {"id":"napoleon-bonaparte.timeline.46.year","translatedText":"February 1808"},
  {"id":"napoleon-bonaparte.timeline.46.event","translatedText":"Roma'yı işgal etti."},
  {"id":"napoleon-bonaparte.timeline.47.year","translatedText":"May 2, 1808"},
  {"id":"napoleon-bonaparte.timeline.47.event","translatedText":"Madrid halkı Fransız ordusuna karşı ayaklandı."},
  {"id":"napoleon-bonaparte.timeline.48.year","translatedText":"May 1809"},
  {"id":"napoleon-bonaparte.timeline.48.event","translatedText":"Papalık Devletleri'ni ilhak etti."},
  {"id":"napoleon-bonaparte.timeline.49.year","translatedText":"June 10, 1809"},
  {"id":"napoleon-bonaparte.timeline.49.event","translatedText":"Papa onu aforoz edince tutuklayıp Savona'ya sürgüne gönderdi."},
  {"id":"napoleon-bonaparte.timeline.50.year","translatedText":"January 10, 1810"},
  {"id":"napoleon-bonaparte.timeline.50.event","translatedText":"İmparatoriçe Joséphine'den boşandı."},
  {"id":"napoleon-bonaparte.timeline.51.year","translatedText":"1810"},
  {"id":"napoleon-bonaparte.timeline.51.event","translatedText":"Avusturya İmparatoru I. Franz'ın kızı Marie Louise ile evlendi."},
  {"id":"napoleon-bonaparte.timeline.52.year","translatedText":"1810"},
  {"id":"napoleon-bonaparte.timeline.52.event","translatedText":"İsveç, Fransa Mareşali Bernadotte'a İsveç tahtının varisliğini teklif etti."},
  {"id":"napoleon-bonaparte.timeline.53.year","translatedText":"1811"},
  {"id":"napoleon-bonaparte.timeline.53.event","translatedText":"Marie Louise, Roma Kralı II. Napolyon'u doğurdu."},
  {"id":"napoleon-bonaparte.timeline.54.year","translatedText":"May 1812"},
  {"id":"napoleon-bonaparte.timeline.54.event","translatedText":"600.000 kişilik büyük bir orduyla Rusya Seferi'ni başlattı."},
  {"id":"napoleon-bonaparte.timeline.55.year","translatedText":"May 1812"},
  {"id":"napoleon-bonaparte.timeline.55.event","translatedText":"Papa'yı zorla Fontainebleau'ya götürdü."},
  {"id":"napoleon-bonaparte.timeline.56.year","translatedText":"September 7, 1812"},
  {"id":"napoleon-bonaparte.timeline.56.event","translatedText":"Borodino yakınlarında yapılan büyük muharebede Fransız ordusu zafer kazandı."},
  {"id":"napoleon-bonaparte.timeline.57.year","translatedText":"September 15, 1812"},
  {"id":"napoleon-bonaparte.timeline.57.event","translatedText":"Moskova'yı işgal etti."},
  {"id":"napoleon-bonaparte.timeline.58.year","translatedText":"October 1812"},
  {"id":"napoleon-bonaparte.timeline.58.event","translatedText":"Fransız ordusu Rusya'dan geri çekildi."},
  {"id":"napoleon-bonaparte.timeline.59.year","translatedText":"January 1813"},
  {"id":"napoleon-bonaparte.timeline.59.event","translatedText":"Papa VII. Pius ile 'Fontainebleau Konkordatosu'nu imzaladı."},
  {"id":"napoleon-bonaparte.timeline.60.year","translatedText":"October 16, 1813"},
  {"id":"napoleon-bonaparte.timeline.60.event","translatedText":"Leipzig Muharebesi'nde müttefik orduları tarafından kuşatılarak ağır bir yenilgiye uğradı."},
  {"id":"napoleon-bonaparte.timeline.61.year","translatedText":"March 31, 1814"},
  {"id":"napoleon-bonaparte.timeline.61.event","translatedText":"Fransa'nın başkenti Paris düştü."},
  {"id":"napoleon-bonaparte.timeline.62.year","translatedText":"April 16, 1814"},
  {"id":"napoleon-bonaparte.timeline.62.event","translatedText":"Fontainebleau Antlaşması'nı imzaladıktan sonra Elba Adası'nın yöneticisi olarak sürgüne gönderildi."},
  {"id":"napoleon-bonaparte.timeline.63.year","translatedText":"February 1815"},
  {"id":"napoleon-bonaparte.timeline.63.event","translatedText":"Elba Adası'ndan kaçtı."},
  {"id":"napoleon-bonaparte.timeline.64.year","translatedText":"March 20, 1815"},
  {"id":"napoleon-bonaparte.timeline.64.event","translatedText":"Paris'e girerek yeniden Fransa İmparatoru oldu."},
  {"id":"napoleon-bonaparte.timeline.65.year","translatedText":"June 1815"},
  {"id":"napoleon-bonaparte.timeline.65.event","translatedText":"Waterloo Muharebesi'nde İngiliz ve Prusya ordularının ortak saldırısıyla yenilgiye uğradı ve Yüz Gün dönemi sona erdi."},
  {"id":"napoleon-bonaparte.timeline.66.year","translatedText":"August 1815"},
  {"id":"napoleon-bonaparte.timeline.66.event","translatedText":"Güney Atlantik'teki Saint Helena'ya sürgüne gönderildi."},
  {"id":"napoleon-bonaparte.timeline.67.year","translatedText":"May 5, 1821"},
  {"id":"napoleon-bonaparte.timeline.67.event","translatedText":"Saat 17:49'da vefat etti."},
  {"id":"napoleon-bonaparte.timeline.68.year","translatedText":"May 1840"},
  {"id":"napoleon-bonaparte.timeline.68.event","translatedText":"Cenazesi Fransa'ya iade edildi ve Paris'teki Les Invalides'e defnedildi."},
  {"id":"napoleon-bonaparte.keyAchievements.0.title","translatedText":"Napolyon Kanunları'nın İlanı"},
  {"id":"napoleon-bonaparte.keyAchievements.0.description","translatedText":"1804 yılında Napolyon Kanunları olarak bilinen Fransız Medeni Kanunu'nu yürürlüğe koyarak tüm dünyadaki medeni hukuk sistemlerini büyük ölçüde etkiledi."},
  {"id":"napoleon-bonaparte.keyAchievements.1.title","translatedText":"Askeri Taktik ve Sistemlerin Geliştirilmesi"},
  {"id":"napoleon-bonaparte.keyAchievements.1.description","translatedText":"Askeri açıdan modern savaşlara kadar etkili oldu; taktik, strateji, eğitim, organizasyon, lojistik, üniforma ve ödül sistemlerini geliştirdi."},
  {"id":"napoleon-bonaparte.keyAchievements.2.title","translatedText":"Toulon Kuşatması Zaferi"},
  {"id":"napoleon-bonaparte.keyAchievements.2.description","translatedText":"1793'teki Toulon Kuşatması'nda zaferi getirdikten sonra 24 yaşında tuğgeneralliğe terfi ederek general oldu."},
  {"id":"napoleon-bonaparte.keyAchievements.3.title","translatedText":"İtalya Seferi'nin Başarısı"},
  {"id":"napoleon-bonaparte.keyAchievements.3.description","translatedText":"1796'daki İtalya Seferi'nde büyük başarılar elde edip Birinci Koalisyon Savaşı'nda art arda zaferler kazanarak askeri kariyerinde hızla yükseldi."},
  {"id":"napoleon-bonaparte.keyAchievements.4.title","translatedText":"Fransa Merkez Bankası'nın Kurulması"},
  {"id":"napoleon-bonaparte.keyAchievements.4.description","translatedText":"1800 yılında Fransa Merkez Bankası'nı kurarak ekonomik istikrarı sağladı."},
  {"id":"napoleon-bonaparte.keyAchievements.5.title","translatedText":"Légion d'honneur Nişanı'nın Kurulması"},
  {"id":"napoleon-bonaparte.keyAchievements.5.description","translatedText":"1802 yılında ünlü Légion d'honneur Nişanı'nı kurdu."}
]
